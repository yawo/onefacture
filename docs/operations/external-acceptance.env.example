# External acceptance environment template.
# Copy values into your shell or GitHub Actions variables/secrets before running:
#   make check-external-env
#   make collect-external-evidence STAMP=YYYY-MM-DD

# Live PA sandbox targets.
ONEFACTURE_CHORUS_BASE_URL=https://piste.example.invalid
ONEFACTURE_CHORUS_ACCESS_TOKEN=replace-with-secret
ONEFACTURE_DOCAPOSTE_BASE_URL=https://docaposte-sandbox.example.invalid
ONEFACTURE_DOCAPOSTE_API_TOKEN=replace-with-secret
ONEFACTURE_PENNYLANE_BASE_URL=https://pennylane-sandbox.example.invalid
ONEFACTURE_PENNYLANE_API_TOKEN=replace-with-secret

# Public sandbox target used for quickstart and fresh-account onboarding evidence.
ONEFACTURE_SANDBOX_URL=https://sandbox.onefacture.example.invalid

# Public package registry proof gate. No env is required for public installs.

# Deployed KMS broker proof gate.
ONEFACTURE_KMS_URL=https://kms-broker.example.invalid
ONEFACTURE_KMS_TOKEN=replace-with-secret-if-required

# Production analytics proof gate.
ONEFACTURE_PROD_API_URL=https://api.onefacture.example.invalid
ONEFACTURE_PROD_API_KEY=replace-with-secret
ONEFACTURE_MIN_RETRIED_INVOICES=1
ONEFACTURE_BASELINE_RETRY_SUCCESS_RATE=0.40

# Evidence metadata. Must not remain placeholder values in real evidence.
ONEFACTURE_EVIDENCE_OPERATOR=replace-with-person-or-automation-identity
ONEFACTURE_EVIDENCE_ENVIRONMENT=replace-with-real-target-name
ONEFACTURE_EVIDENCE_LINKS=https://ci-or-release-or-audit-url.example.invalid
